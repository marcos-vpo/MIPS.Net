<Window x:Class="MIPS.Desktop.CreateDevice"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MIPS.Desktop"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Background="WhiteSmoke"
        Title="Create a external Device" Height="408" Width="490">
    <Grid>
        <GroupBox Header="Device Type" Margin="10,41,10,150">
            <Grid Height="181">
                <RadioButton x:Name="rdoStorage" Content="Storage Device" HorizontalAlignment="Left" Margin="10,6,0,0" VerticalAlignment="Top" Width="154" Checked="rdoStorage_Checked" FontFamily="Segoe UI Semibold" Height="18" FontSize="14"/>
                <RadioButton x:Name="rdoDisplay" Content="Display Device" HorizontalAlignment="Left" Margin="10,26,0,0" VerticalAlignment="Top" Width="154" Checked="rdoDisplay_Checked" FontFamily="Segoe UI Semibold" FontSize="14"/>
                <RadioButton x:Name="rdoPrinter" Content="Printer Device" HorizontalAlignment="Left" Margin="10,48,0,0" VerticalAlignment="Top" Width="154" Checked="rdoPrinter_Checked" FontFamily="Segoe UI Semibold" FontSize="14"/>
                <RadioButton x:Name="rdoNet" Content="Network Device" HorizontalAlignment="Left" Margin="10,68,0,0" VerticalAlignment="Top" Width="154" Checked="rdoNet_Checked" FontFamily="Segoe UI Semibold" FontSize="14" />
                <RadioButton x:Name="rdoDebug" Content="Remote Debugger" HorizontalAlignment="Left" Margin="10,86,0,0" VerticalAlignment="Top" Width="154" Checked="rdoDebug_Checked" FontFamily="Segoe UI Semibold" FontSize="14" />
                <Image x:Name="imgDevice" HorizontalAlignment="Right" Margin="0,5,10,61" Width="125"/>
                <TextBlock x:Name="lbInfoDev" Margin="10,0,10,10" TextWrapping="Wrap" VerticalAlignment="Bottom" Height="42" FontSize="12" FontFamily="Segoe UI Semibold" Foreground="#FF464646"/>

            </Grid>
        </GroupBox>
        <Label Content="External program path" HorizontalAlignment="Left" Margin="10,0,0,119" VerticalAlignment="Bottom" Width="173"/>
        <TextBox x:Name="txExe" Margin="10,0,10,60" TextWrapping="Wrap" Height="54" VerticalAlignment="Bottom"/>
        <Button x:Name="btnSelExe" Padding="0" BorderBrush="#FF7B7B7B" HorizontalAlignment="Left" Margin="10,0,0,9" VerticalAlignment="Bottom" Width="110" Height="27" Click="btnSelExe_Click">
            <Grid Width="103">
                <Image Source="/icons/select_app.png" Width="20" HorizontalAlignment="Left"/>
                <TextBlock Margin="22,0,1,0" FontSize="14"><Run Text="Select app"/><Run Language="pt-br" Text="..."/></TextBlock>
            </Grid>
        </Button>
        <Button x:Name="btnCreate" Content="Create" HorizontalAlignment="Right" Margin="0,0,10,9" VerticalAlignment="Bottom" Height="29" Width="79" Background="#FF0075B3" Foreground="White" BorderBrush="#FF0089D0" Click="btnCreate_Click"/>
        <Label Content="Device custom name: " HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txName" Margin="136,14,10,0" TextWrapping="Wrap" VerticalAlignment="Top"/>

    </Grid>
</Window>
