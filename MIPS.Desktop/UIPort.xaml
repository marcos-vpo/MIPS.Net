<UserControl x:Class="MIPS.Desktop.UIPort"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MIPS.Desktop"
             Padding="10,0,0,0"
             mc:Ignorable="d" Height="68" Width="128">
    <Grid Background="#FF0E4A0A" >
        <Grid Background="White" Margin="0,10,0,0">
            <Image x:Name="imgPort" Source="/icons/usb.png" HorizontalAlignment="Left" Margin="4,0,0,34" Width="22"/>
            <Image x:Name="imgDev"  HorizontalAlignment="Left" Margin="4,25,0,9" Width="23"/>
            <TextBlock x:Name="lbDev" Margin="31,1,4,4" TextWrapping="Wrap" Text="TextBlock"/>
            <Ellipse x:Name="elStatus" HorizontalAlignment="Left" Height="7" Margin="11,0,0,2" StrokeThickness="4" Stroke="Black" VerticalAlignment="Bottom" Width="7"/>
        </Grid>
    </Grid>
</UserControl>
