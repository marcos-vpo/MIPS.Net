<Window x:Class="MIPS.Desktop.CreateSystem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MIPS.Desktop"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Background="WhiteSmoke"
        Title="Create System" Height="396" Width="847">
    <Grid>
        <Label Content="Your System Name:" HorizontalAlignment="Left" Margin="15,13,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txName" Margin="132,17,0,0" TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Left" Width="264"/>
        <Label Content="Vendor Name:" HorizontalAlignment="Left" Margin="15,36,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txVendor" Margin="132,40,0,0" TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Left" Width="264"/>
        <Image Source="/icons/ram.png" HorizontalAlignment="Left" Height="28" Margin="14,62,0,0" VerticalAlignment="Top" Width="32"/>
        <Label Content="Memory size:" HorizontalAlignment="Left" Margin="47,62,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txMem" HorizontalAlignment="Left" Margin="132,67,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="93" Text="4096"/>
        <Label Content="(bytes)" HorizontalAlignment="Left" Margin="225,63,0,0" VerticalAlignment="Top" Width="81"/>

        <DataGrid x:Name="dataGridPorts" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="True" Margin="10,169,0,10" HorizontalAlignment="Left" Width="409">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IDStr}" Width="50" />
                <DataGridTextColumn Header="Class" Binding="{Binding ClassStr}" Width="100" />
                <DataGridTextColumn Header="Device" Binding="{Binding Device.Name}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Ports and devices" HorizontalAlignment="Left" Margin="10,95,0,0" VerticalAlignment="Top" FontFamily="Segoe UI Semibold"/>
        <ComboBox x:Name="cbPortType" HorizontalAlignment="Left" Margin="10,142,0,0" VerticalAlignment="Top" Width="137"/>
        <ComboBox x:Name="cbDevice" Margin="152,142,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="174"/>
        <Button x:Name="btnAdd" Content="Add" HorizontalAlignment="Left" Margin="331,142,0,0" VerticalAlignment="Top" Height="22" Width="88" Click="btnAdd_Click"/>
        <Label Content="Port type" HorizontalAlignment="Left" Margin="10,116,0,0" VerticalAlignment="Top"/>
        <Label Content="Device" HorizontalAlignment="Left" Margin="152,116,0,0" VerticalAlignment="Top" Width="55"/>
        <Button x:Name="btnCreate" Content="Create" HorizontalAlignment="Right" Margin="0,15,10,0" Width="86" Background="#FF0075B3" Foreground="White" BorderBrush="#FF0089D0" Click="btnCreate_Click" Height="34" VerticalAlignment="Top"/>
        <Button Content="Setup a new device..." HorizontalAlignment="Left" Margin="212,119,0,0" VerticalAlignment="Top" Background="Transparent" BorderBrush="Transparent" Foreground="#FF0279FF" Width="114" Click="btnNewDev_Click"/>
        <Label Content="System Buttons" HorizontalAlignment="Left" Margin="424,95,0,0" VerticalAlignment="Top" FontFamily="Segoe UI Semibold"/>
        <DataGrid x:Name="dataGridButtons" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False" CanUserDeleteRows="True" Margin="424,169,10,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" IsReadOnly="True" Binding="{Binding IDStr}" Width="50" />
                <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="btnAddSysButton" Content="Add Button" Margin="726,142,10,0" VerticalAlignment="Top" Height="22" Click="btnAddSysButton_Click"/>
        <TextBox x:Name="txButtoNText" Margin="424,146,0,0" TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Left" Width="264"/>
        <Label Content="Button text" HorizontalAlignment="Left" Margin="424,115,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
