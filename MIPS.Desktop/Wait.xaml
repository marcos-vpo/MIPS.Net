<Window x:Class="MIPS.Desktop.Wait"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MIPS.Desktop"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Gray"
        Title="Wait" Height="51" Width="220">
    <Grid>
        <Grid Margin="1,1,1,1" Background="White">
            <ProgressBar IsIndeterminate="True" Margin="0,31,0,8"/>
            <TextBlock HorizontalAlignment="Left" Margin="7,2,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontFamily="Segoe UI Semibold" Width="70"><Run Language="pt-br" Text="Wait..."/></TextBlock>
            <Border BorderBrush="#FF00A7FF" BorderThickness="1" Margin="0,21,0,0" Height="2" VerticalAlignment="Top"/>
        </Grid>

    </Grid>
</Window>
