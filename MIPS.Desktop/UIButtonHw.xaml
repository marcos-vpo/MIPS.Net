<UserControl x:Class="MIPS.Desktop.UIButtonHw"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MIPS.Desktop"
             mc:Ignorable="d" 
             Background="White" Height="41" Width="100">
    <Grid>
        <Button x:Name="btn" IsEnabled="False" Click="btn_Click" Margin="1,1,1,1">
            <Button.Content>
                <Grid Width="94" Height="35">
                    <TextBlock Text="Button" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Center" Margin="0,0,6,0" />
                    <Button Content="?" Foreground="DodgerBlue" Background="WhiteSmoke" BorderThickness="0" Padding="0" HorizontalAlignment="Right" Width="6" Click="HlpButton_Click" />
                </Grid>
            </Button.Content>
        </Button>

    </Grid>
</UserControl>
